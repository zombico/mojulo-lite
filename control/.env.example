# Mojulo-Lite Control Plane — local env example

# Path to lite-template source, used by DockerDeployer to package artifacts
LITE_TEMPLATE_PATH=../lite-template

# Where generated bot zip artifacts get written (also served for download)
ARTIFACTS_DIR=./data/artifacts

# SQLite database file (auto-created on first run)
SQLITE_PATH=./data/mojulo-lite.db

# Local filesystem storage root for uploaded documents (parsed text + originals)
STORAGE_ROOT=./data/storage

# Default Docker image tag the generated docker-compose.yml references
BOT_IMAGE=mojulo/bot:latest

# Default port the bot container exposes
BOT_DEFAULT_PORT=3000
