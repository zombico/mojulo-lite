# Mojulo-Lite Control Plane — local env example

# Path to lite-template source, used by DockerDeployer to package artifacts
LITE_TEMPLATE_PATH=../lite-template

# Where generated bot zip artifacts get written (also served for download)
ARTIFACTS_DIR=./data/artifacts

# SQLite database file (auto-created on first run)
SQLITE_PATH=./data/mojulo-lite.db

# Local filesystem storage root for uploaded documents (parsed text + originals)
STORAGE_ROOT=./data/storage

# Default Docker image tag the generated docker-compose.yml references.
# Pin to the exact published GHCR image so users pull the vector-capable build.
BOT_IMAGE=ghcr.io/zombico/mojulo-bot:0.3.0

# Default port the bot container exposes
BOT_DEFAULT_PORT=3000

# Optional login on the control plane. Leave blank to disable (default).
# Set BOTH to gate every route behind /login (except /api/health).
# Sessions are signed with the password itself — rotating the password
# invalidates all outstanding sessions automatically.
# This is a last-line-of-defense affordance — do NOT expose the control plane to
# the public internet, and front it with HTTPS (reverse proxy) if you enable it.
CONTROL_PLANE_USER=
CONTROL_PLANE_PASSWORD=
