# LLM API Keys (at least one required)
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Mojulo API Key (required for protected admin endpoints)
# This key is set by the control server during deployment
# Used to secure /api/conversations endpoints
MOJULO_API_KEY=your_secure_api_key_here

# Docker environment flag (set automatically in containers)
DOCKER_RUN=true
